                          "fill": "$color-text-1",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "class Orchestrator:\n    def __init__(self, graph: Subgraph):\n        self.graph = graph\n        self.examiner = ExaminerAgent(graph)\n        self.prober   = ProberAgent(graph)\n        self.grader   = GraderAgent()\n\n    async def step(self, answer: Answer):\n        next_focus = self.prober.pick(answer, self.graph)\n        question   = await self.examiner.compose(next_focus)\n        return question",
                          "lineHeight": 1.7,
                          "fontFamily": "$font-code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
